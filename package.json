{
  "name": "claude-code-usage-check-in-statusbar",
  "displayName": "Claude Code Usage Check in Status Bar",
  "description": "Display Claude Code API rate limit usage in VSCode status bar",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeCodeUsage.refresh",
        "title": "Claude Code Usage: Refresh"
      },
      {
        "command": "claudeCodeUsage.showOutput",
        "title": "Claude Code Usage: Show Output"
      }
    ],
    "configuration": {
      "title": "Claude Code Usage Check in Status Bar",
      "properties": {
        "claudeCodeUsage.intervalMinutes": {
          "type": "number",
          "default": 20,
          "description": "API polling interval in minutes (0 to disable auto-refresh)"
        },
        "claudeCodeUsage.credentialsPath": {
          "type": "string",
          "default": "~/.claude/.credentials.json",
          "description": "Path to Claude credentials file (supports ~ for home directory)"
        },
        "claudeCodeUsage.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Claude Code Usage status bar display"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1"
  }
}
